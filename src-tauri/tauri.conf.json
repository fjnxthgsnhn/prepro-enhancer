{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prepro Enhancer",
  "version": "0.1.0",
  "identifier": "com.preproenhancer.desktop",
  "build": {
    "beforeBuildCommand": "npm run build:web",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Prepro Enhancer",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyRUY0MTk1N0E0MzVFMkUKUldRdVhrTjZsVUh2VWpUOVFKemdnbW9RV1MxRmRXcXN2STdVN3dzNHNMQVgzMDcyRkdEbjhRYW8K",
      "endpoints": [
        "https://fjnxthgsnhn.github.io/prepro-enhancer/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
